@import "tailwindcss";
/*
  ---break---
*/
@custom-variant dark (&:is(.dark *));

@import "tw-animate-css";

@variant dark (&:is(.dark *));

@theme {
  --color-background: hsl(var(--background));
  --color-foreground: hsl(var(--foreground));

  --color-card: hsl(var(--card));
  --color-card-foreground: hsl(var(--card-foreground));

  --color-popover: hsl(var(--popover));
  --color-popover-foreground: hsl(var(--popover-foreground));

  --color-primary: hsl(var(--primary));
  --color-primary-foreground: hsl(var(--primary-foreground));

  --color-secondary: hsl(var(--secondary));
  --color-secondary-foreground: hsl(var(--secondary-foreground));

  --color-muted: hsl(var(--muted));
  --color-muted-foreground: hsl(var(--muted-foreground));

  --color-accent: hsl(var(--accent));
  --color-accent-foreground: hsl(var(--accent-foreground));

  --color-destructive: hsl(var(--destructive));
  --color-destructive-foreground: hsl(var(--destructive-foreground));

  --color-border: hsl(var(--border));
  --color-input: hsl(var(--input));
  --color-ring: hsl(var(--ring));

  --color-chart-1: hsl(var(--chart-1));
  --color-chart-2: hsl(var(--chart-2));
  --color-chart-3: hsl(var(--chart-3));
  --color-chart-4: hsl(var(--chart-4));
  --color-chart-5: hsl(var(--chart-5));

  --color-sidebar: hsl(var(--sidebar-background));
  --color-sidebar-foreground: hsl(var(--sidebar-foreground));
  --color-sidebar-primary: hsl(var(--sidebar-primary));
  --color-sidebar-primary-foreground: hsl(var(--sidebar-primary-foreground));
  --color-sidebar-accent: hsl(var(--sidebar-accent));
  --color-sidebar-accent-foreground: hsl(var(--sidebar-accent-foreground));
  --color-sidebar-border: hsl(var(--sidebar-border));
  --color-sidebar-ring: hsl(var(--sidebar-ring));

  --radius-lg: var(--radius);
  --radius-md: calc(var(--radius) - 2px);
  --radius-sm: calc(var(--radius) - 4px);
}

/*
  The default border color has changed to `currentColor` in Tailwind CSS v4,
  so we've added these compatibility styles to make sure everything still
  looks the same as it did with Tailwind CSS v3.

  If we ever want to remove these styles, we need to add an explicit border
  color utility to any element that depends on these defaults.
*/
@layer base {
  *,
  ::after,
  ::before,
  ::backdrop,
  ::file-selector-button {
    border-color: var(--color-gray-200, currentColor);
  }
}

@layer utilities {
  body {
    font-family: "Manrope", Arial, Helvetica, sans-serif;
  }
  
  /* AutoSRE Custom Animations */
  @keyframes spin-slow {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }
  
  .animate-spin-slow {
    animation: spin-slow 8s linear infinite;
  }
  
  /* Enhanced gradient animations */
  @keyframes gradient-x {
    0%, 100% {
      transform: translateX(0%);
    }
    50% {
      transform: translateX(100%);
    }
  }
  
  .animate-gradient-x {
    animation: gradient-x 3s ease infinite;
    background-size: 400% 400%;
  }
  
  /* Pulse glow effect */
  @keyframes pulse-glow {
    0%, 100% {
      box-shadow: 0 0 5px hsl(var(--primary) / 0.5);
    }
    50% {
      box-shadow: 0 0 20px hsl(var(--primary) / 0.8), 0 0 30px hsl(var(--accent) / 0.4);
    }
  }
  
  .animate-pulse-glow {
    animation: pulse-glow 2s ease-in-out infinite;
  }
  
  /* Gruvbox Terminal Aesthetic */
  .terminal-window {
    background: hsl(25 18% 16%);
    border: 1px solid hsl(30 11% 57%);
    font-family: 'JetBrains Mono', 'Fira Code', 'SF Mono', monospace;
  }
  
  .terminal-header {
    background: linear-gradient(90deg, hsl(4 100% 59%), hsl(45 100% 57%), hsl(65 60% 51%));
    height: 24px;
    display: flex;
    align-items: center;
    padding: 0 12px;
    border-radius: 0.5rem 0.5rem 0 0;
  }
  
  .terminal-dots {
    display: flex;
    gap: 6px;
  }
  
  .terminal-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }
  
  .terminal-dot.red { background: hsl(4 100% 59%); }
  .terminal-dot.yellow { background: hsl(45 100% 57%); }
  .terminal-dot.green { background: hsl(65 60% 51%); }
  
  /* Code/Log styling */
  .gruvbox-code {
    background: hsl(25 18% 16%);
    color: hsl(60 9% 87%);
    border: 1px solid hsl(30 11% 57%);
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.875rem;
    line-height: 1.5;
  }
  
  /* Status indicators with Gruvbox colors */
  .status-critical { color: hsl(4 100% 59%); background: hsl(4 100% 59% / 0.1); }
  .status-high { color: hsl(24 100% 55%); background: hsl(24 100% 55% / 0.1); }
  .status-medium { color: hsl(45 100% 57%); background: hsl(45 100% 57% / 0.1); }
  .status-low { color: hsl(65 60% 51%); background: hsl(65 60% 51% / 0.1); }
  .status-success { color: hsl(65 60% 51%); background: hsl(65 60% 51% / 0.1); }
}

@layer base {
  :root {
    /* AutoSRE Gruvbox Light Theme */
    --background: 60 9% 87%;      /* #ebdbb2 - Light background */
    --foreground: 25 18% 25%;     /* #3c3836 - Dark text */
    --card: 60 9% 87%;
    --card-foreground: 25 18% 25%;
    --popover: 60 9% 87%;
    --popover-foreground: 25 18% 25%;
    
    /* Primary: Gruvbox Blue */
    --primary: 205 60% 67%;       /* #83a598 */
    --primary-foreground: 0 0% 100%;
    
    /* Secondary: Gruvbox Gray */
    --secondary: 30 11% 57%;      /* #928374 */
    --secondary-foreground: 0 0% 100%;
    
    --muted: 30 11% 57%;
    --muted-foreground: 25 18% 25%;
    
    /* Accent: Gruvbox Orange */
    --accent: 24 100% 55%;        /* #fe8019 */
    --accent-foreground: 0 0% 100%;
    
    --destructive: 4 100% 59%;    /* #fb4934 - Gruvbox Red */
    --destructive-foreground: 0 0% 100%;
    
    --border: 30 11% 57%;
    --input: 30 11% 57%;
    --ring: 205 60% 67%;
    
    /* Gruvbox Chart Colors */
    --chart-1: 205 60% 67%;       /* Blue */
    --chart-2: 65 60% 51%;        /* Green #b8bb26 */
    --chart-3: 343 100% 59%;      /* Red #fb4934 */
    --chart-4: 45 100% 57%;       /* Yellow #fabd2f */
    --chart-5: 15 100% 69%;       /* Purple #d3869b */
    
    --radius: 0.75rem;
    
    /* Sidebar Gruvbox theme */
    --sidebar-background: 60 9% 87%;
    --sidebar-foreground: 25 18% 25%;
    --sidebar-primary: 205 60% 67%;
    --sidebar-primary-foreground: 0 0% 100%;
    --sidebar-accent: 24 100% 95%;
    --sidebar-accent-foreground: 205 60% 67%;
    --sidebar-border: 30 11% 57%;
    --sidebar-ring: 205 60% 67%;
  }

  .dark {
    /* AutoSRE Gruvbox Dark Theme */
    --background: 25 18% 16%;     /* #282828 - Dark background */
    --foreground: 60 9% 87%;      /* #ebdbb2 - Light text */
    --card: 25 18% 20%;           /* #32302f - Soft background */
    --card-foreground: 60 9% 87%;
    --popover: 25 18% 20%;
    --popover-foreground: 60 9% 87%;
    
    /* Primary: Gruvbox Blue */
    --primary: 205 60% 67%;       /* #83a598 */
    --primary-foreground: 25 18% 16%;
    
    /* Secondary: Gruvbox Gray */
    --secondary: 30 11% 57%;      /* #928374 */
    --secondary-foreground: 60 9% 87%;
    
    --muted: 25 18% 20%;
    --muted-foreground: 30 11% 57%;
    
    /* Accent: Gruvbox Orange */
    --accent: 24 100% 55%;        /* #fe8019 */
    --accent-foreground: 25 18% 16%;
    
    --destructive: 4 100% 59%;    /* #fb4934 */
    --destructive-foreground: 60 9% 87%;
    
    --border: 30 11% 57%;
    --input: 30 11% 57%;
    --ring: 205 60% 67%;
    
    /* Gruvbox Chart Colors - Enhanced for dark theme */
    --chart-1: 205 60% 67%;       /* Blue */
    --chart-2: 65 60% 51%;        /* Green */
    --chart-3: 4 100% 59%;        /* Red */
    --chart-4: 45 100% 57%;       /* Yellow */
    --chart-5: 15 100% 69%;       /* Purple */
    
    /* Dark sidebar */
    --sidebar-background: 25 18% 16%;
    --sidebar-foreground: 60 9% 87%;
    --sidebar-primary: 205 60% 67%;
    --sidebar-primary-foreground: 25 18% 16%;
    --sidebar-accent: 25 18% 20%;
    --sidebar-accent-foreground: 205 60% 67%;
    --sidebar-border: 30 11% 57%;
    --sidebar-ring: 205 60% 67%;
  }
    
    /* Accent: Electric Blue */
    --accent: 199 89% 48%;
    --accent-foreground: 234 15% 6%;
    
    --destructive: 0 75% 60%;
    --destructive-foreground: 218 27% 94%;
    
    --border: 234 15% 18%;
    --input: 234 15% 18%;
    --ring: 217 91% 60%;
    
    /* Enhanced Dark Chart Colors */
    --chart-1: 217 91% 60%;  /* Electric Blue */
    --chart-2: 168 76% 42%;  /* Teal */
    --chart-3: 271 81% 65%;  /* Bright Purple */
    --chart-4: 142 76% 45%;  /* Bright Green */
    --chart-5: 346 84% 65%;  /* Bright Pink */
    
    /* Dark Sidebar with subtle gradient */
    --sidebar-background: 234 15% 4%;
    --sidebar-foreground: 218 27% 85%;
    --sidebar-primary: 217 91% 60%;
    --sidebar-primary-foreground: 234 15% 6%;
    --sidebar-accent: 234 15% 15%;
    --sidebar-accent-foreground: 217 91% 60%;
    --sidebar-border: 234 15% 18%;
    --sidebar-ring: 217 91% 60%;
  }

@layer base {
  * {
    @apply border-border;
  }
  body {
    @apply bg-background text-foreground;
  }
}

/*
  ---break---
*/

:root {
  --background: hsl(0 0% 100%);
  --foreground: hsl(240 10% 3.9%);
  --card: hsl(0 0% 100%);
  --card-foreground: hsl(240 10% 3.9%);
  --popover: hsl(0 0% 100%);
  --popover-foreground: hsl(240 10% 3.9%);
  --primary: hsl(240 5.9% 10%);
  --primary-foreground: hsl(0 0% 98%);
  --secondary: hsl(240 4.8% 95.9%);
  --secondary-foreground: hsl(240 5.9% 10%);
  --muted: hsl(240 4.8% 95.9%);
  --muted-foreground: hsl(240 3.8% 46.1%);
  --accent: hsl(240 4.8% 95.9%);
  --accent-foreground: hsl(240 5.9% 10%);
  --destructive: hsl(0 84.2% 60.2%);
  --destructive-foreground: hsl(0 0% 98%);
  --border: hsl(240 5.9% 90%);
  --input: hsl(240 5.9% 90%);
  --ring: hsl(240 10% 3.9%);
  --chart-1: hsl(12 76% 61%);
  --chart-2: hsl(173 58% 39%);
  --chart-3: hsl(197 37% 24%);
  --chart-4: hsl(43 74% 66%);
  --chart-5: hsl(27 87% 67%);
  --radius: 0.6rem;
}

/*
  ---break---
*/

.dark {
  --background: hsl(240 10% 3.9%);
  --foreground: hsl(0 0% 98%);
  --card: hsl(240 10% 3.9%);
  --card-foreground: hsl(0 0% 98%);
  --popover: hsl(240 10% 3.9%);
  --popover-foreground: hsl(0 0% 98%);
  --primary: hsl(0 0% 98%);
  --primary-foreground: hsl(240 5.9% 10%);
  --secondary: hsl(240 3.7% 15.9%);
  --secondary-foreground: hsl(0 0% 98%);
  --muted: hsl(240 3.7% 15.9%);
  --muted-foreground: hsl(240 5% 64.9%);
  --accent: hsl(240 3.7% 15.9%);
  --accent-foreground: hsl(0 0% 98%);
  --destructive: hsl(0 62.8% 30.6%);
  --destructive-foreground: hsl(0 0% 98%);
  --border: hsl(240 3.7% 15.9%);
  --input: hsl(240 3.7% 15.9%);
  --ring: hsl(240 4.9% 83.9%);
  --chart-1: hsl(220 70% 50%);
  --chart-2: hsl(160 60% 45%);
  --chart-3: hsl(30 80% 55%);
  --chart-4: hsl(280 65% 60%);
  --chart-5: hsl(340 75% 55%);
}

/*
  ---break---
*/

@theme inline {
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --color-card: var(--card);
  --color-card-foreground: var(--card-foreground);
  --color-popover: var(--popover);
  --color-popover-foreground: var(--popover-foreground);
  --color-primary: var(--primary);
  --color-primary-foreground: var(--primary-foreground);
  --color-secondary: var(--secondary);
  --color-secondary-foreground: var(--secondary-foreground);
  --color-muted: var(--muted);
  --color-muted-foreground: var(--muted-foreground);
  --color-accent: var(--accent);
  --color-accent-foreground: var(--accent-foreground);
  --color-destructive: var(--destructive);
  --color-destructive-foreground: var(--destructive-foreground);
  --color-border: var(--border);
  --color-input: var(--input);
  --color-ring: var(--ring);
  --color-chart-1: var(--chart-1);
  --color-chart-2: var(--chart-2);
  --color-chart-3: var(--chart-3);
  --color-chart-4: var(--chart-4);
  --color-chart-5: var(--chart-5);
  --radius-sm: calc(var(--radius) - 4px);
  --radius-md: calc(var(--radius) - 2px);
  --radius-lg: var(--radius);
  --radius-xl: calc(var(--radius) + 4px);
}

/*
  ---break---
*/

@layer base {
  * {
    @apply border-border outline-ring/50;
  }
  body {
    @apply bg-background text-foreground;
  }
}

/* Custom styles for markdown content */
@layer utilities {
  .markdown-content {
    @apply text-sm leading-relaxed;
    max-width: 100%;
    width: 100%;
    overflow: hidden;
    contain: layout;
  }
  
  .markdown-content h1 {
    @apply text-lg font-bold mt-4 mb-2;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }
  
  .markdown-content h2 {
    @apply text-base font-semibold mt-3 mb-2;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }
  
  .markdown-content h3 {
    @apply text-sm font-semibold mt-2 mb-1;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }
  
  .markdown-content ul {
    @apply list-disc space-y-1;
    padding-left: 1.25rem;
    max-width: 100%;
  }
  
  .markdown-content ol {
    @apply list-decimal space-y-1;
    padding-left: 1.25rem;
    max-width: 100%;
  }
  
  .markdown-content li {
    @apply text-sm;
    word-wrap: break-word;
    overflow-wrap: break-word;
    padding-right: 1rem;
  }
  
  .markdown-content p {
    @apply text-sm mb-2;
    word-wrap: break-word;
    overflow-wrap: break-word;
    max-width: 100%;
  }
  
  .markdown-content pre {
    @apply my-2 rounded-md;
    max-width: 100%;
    overflow-x: auto;
    overflow-y: hidden;
  }
  
  .markdown-content code {
    @apply bg-gray-200 dark:bg-gray-700 px-1 py-0.5 rounded text-xs font-mono;
    word-break: break-word;
  }
  
  .markdown-content pre code {
    @apply bg-transparent p-0 block;
    word-break: normal;
    white-space: pre;
    overflow-x: auto;
  }
  
  /* Fix for right shift issue */
  .markdown-content > * {
    max-width: 100%;
    overflow-wrap: break-word;
    word-break: break-word;
  }
  
  /* Ensure code blocks don't cause horizontal scroll */
  .markdown-content pre,
  .markdown-content .prism-code {
    max-width: 100%;
    overflow-x: auto;
  }
  
  /* Prevent long strings from overflowing */
  .markdown-content {
    word-wrap: break-word;
    overflow-wrap: break-word;
    hyphens: auto;
  }
  
  /* Specific fixes for lists */
  .markdown-content ul > li,
  .markdown-content ol > li {
    margin-left: 0;
    padding-left: 0.25rem;
  }
}

/* Custom scrollbar styles */
@layer utilities {
  /* Custom scrollbar for webkit browsers */
  .custom-scrollbar::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }

  .custom-scrollbar::-webkit-scrollbar-track {
    @apply bg-gray-100 dark:bg-gray-800 rounded-full;
  }

  .custom-scrollbar::-webkit-scrollbar-thumb {
    @apply bg-gray-300 dark:bg-gray-600 rounded-full hover:bg-gray-400 dark:hover:bg-gray-500 transition-colors;
  }

  /* Firefox scrollbar styles */
  .custom-scrollbar {
    scrollbar-width: thin;
    scrollbar-color: rgb(209 213 219) rgb(243 244 246);
  }

  .dark .custom-scrollbar {
    scrollbar-color: rgb(75 85 99) rgb(31 41 55);
  }
}
