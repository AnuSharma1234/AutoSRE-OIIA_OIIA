# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Database
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/autosre

# Redis
REDIS_URL=redis://localhost:6379/0

# Kubernetes
KUBECONFIG=/path/to/kubeconfig
CLUSTER_ID=prod-cluster-01

# Security
API_SECRET_KEY=your-secret-key-here

# Auto-execution thresholds (0.0-1.0)
AUTO_EXECUTE_LOW_THRESHOLD=0.9
AUTO_EXECUTE_MEDIUM_THRESHOLD=0.9

# ---------- Trigger Service / Event Poller ----------

# SpacetimeDB
SPACETIMEDB_URL=ws://localhost:3000
SPACETIMEDB_MODULE=autosre
SPACETIMEDB_TOKEN=your-spacetimedb-token

# Kubernetes Event Watcher
K8S_NAMESPACE=default
K8S_IN_CLUSTER=false

# Prometheus / AlertManager
PROMETHEUS_URL=http://localhost:9090
ALERTMANAGER_WEBHOOK_SECRET=your-webhook-secret

# Superplane (workflow orchestrator)
SUPERPLANE_WEBHOOK_URL=https://api.superplane.dev/v1/runs
SUPERPLANE_API_KEY=your-superplane-api-key

# Service
SERVICE_PORT=8001
LOG_LEVEL=info
